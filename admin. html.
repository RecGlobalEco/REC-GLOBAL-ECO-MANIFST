<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>RADAME | ADMIN COMMAND CENTER</title>
    <style>
        :root { --admin-red: #ff3e3e; --admin-blue: #00d1ff; --bg: #050505; }
        body { background: var(--bg); color: var(--admin-blue); font-family: 'Courier New', monospace; margin: 0; overflow: hidden; }
        
        header { 
            background: #111; padding: 10px 20px; border-bottom: 2px solid var(--admin-red);
            display: flex; justify-content: space-between; align-items: center;
        }

        .grid-container {
            display: grid; grid-template-columns: 1fr 350px; grid-template-rows: 1fr 200px;
            height: calc(100vh - 50px); gap: 10px; padding: 10px;
        }

        /* MAPA FLOTY - TWOJE WSZYSTKO */
        .fleet-map { 
            grid-row: 1 / 2; background: #0a0a0a; border: 1px solid #333; position: relative;
            background-image: radial-gradient(#1a1a1a 1px, transparent 1px); background-size: 20px 20px;
        }
        .drone-point {
            position: absolute; width: 10px; height: 10px; background: var(--admin-red);
            border-radius: 50%; box-shadow: 0 0 10px var(--admin-red); animation: pulse 2s infinite;
        }

        /* STATUSY MASZYN */
        .side-panel { grid-row: 1 / 3; background: #111; border-left: 1px solid var(--admin-red); padding: 15px; overflow-y: auto; }
        .machine-card { border: 1px solid #222; padding: 10px; margin-bottom: 10px; font-size: 12px; }
        .status-ok { color: #00ff41; }

        /* KONSOLA SYSTEMOWA */
        .console { grid-column: 1 / 2; background: #000; border: 1px solid #222; padding: 10px; font-size: 12px; color: #666; }

        @keyframes pulse { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(3); opacity: 0; } }
    </style>
</head>
<body>

<header>
    <div style="color: var(--admin-red); font-weight: bold;">[ SYSTEM ADMIN ACCESS: GRANTED ]</div>
    <div>ACTIVE UNITS: 12 | TOTAL REVENUE: <span style="color: #00ff41;">1,240.50 SOL</span></div>
</header>

<div class="grid-container">
    <div class="fleet-map">
        <div style="position: absolute; top: 10px; left: 10px; font-size: 10px;">LIVE ASSET TRACKING (GPS_DEPIN)</div>
        <div class="drone-point" style="top: 20%; left: 30%;"></div>
        <div class="drone-point" style="top: 50%; left: 70%;"></div>
        <div class="drone-point" style="top: 80%; left: 45%;"></div>
    </div>

    <div class="side-panel">
        <h3>FLOTA OPERACYJNA</h3>
        
        <div class="machine-card">
            <b>UNIT: RADAME-X1 (WARSAW)</b><br>
            STATUS: <span class="status-ok">WORKING</span><br>
            LOAD: 85% | TEMP: 42°C<br>
            TOTAL YIELD: 14.2 SOL
        </div>

        <div class="machine-card">
            <b>UNIT: HUB-DE-04 (BERLIN)</b><br>
            STATUS: <span class="status-ok">STANDBY</span><br>
            LOAD: 0% | TEMP: 20°C<br>
            TOTAL YIELD: 102.8 SOL
        </div>

        <div class="machine-card" style="border-color: var(--admin-red);">
            <b>UNIT: MOBILE-RE-09 (DUBAI)</b><br>
            STATUS: <span style="color: var(--admin-red);">MAINTENANCE</span><br>
            ERROR: SENSOR_OFFLINE<br>
            <button style="background: var(--admin-red); border:none; color:#000; font-size:10px; margin-top:5px;">REMOTE RESET</button>
        </div>
    </div>

    <div class="console">
        > Initializing secure connection... OK<br>
        > Fetching Solana Blockchain data... OK<br>
        > Transaction detected: 5.80 SOL (Lot #14 sold)<br>
        > Fleet GPS sync complete. All systems nominal.
    </div>
</div>

</body>
</html>
